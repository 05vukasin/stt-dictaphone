# Production .env template. Copy to .env on the deployment host, fill in
# real values, never commit the live .env.

# --- Image ---
# Pin to a specific tag in production. Update + redeploy when a new release
# is published. Avoids accidental rollouts of a moving `:latest`.
IMAGE_TAG=0.2.0

# --- Required at runtime ---

# Random 32+ byte secret. Used by Better Auth to sign session cookies,
# rotate JWKS signing keys, AND derive the AES-GCM key that protects API
# keys at rest. Rotating this secret requires running
# scripts/rotate-secret-encryption.ts FIRST (see .claude/DECISIONS.md #11).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL the browser uses. Must match the actual origin behind
# your reverse proxy / CDN, otherwise auth cookies will not stick.
# Example: https://dictaphone.example.com
BETTER_AUTH_URL=

# --- First-boot admin seed (consumed only when the users table has no admin) ---

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# --- Postgres ---

POSTGRES_USER=dictaphone
POSTGRES_PASSWORD=
POSTGRES_DB=dictaphone

# --- Optional ---

# Host port the web service binds to. Behind a reverse proxy, leave at 3000
# and have the proxy upstream to `http://localhost:3000`.
WEB_PORT=3000

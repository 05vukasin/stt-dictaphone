# --- Required at runtime ---

# Postgres connection string. In docker-compose this points at the bundled
# postgres service; override for production.
DATABASE_URL=postgres://dictaphone:dictaphone@postgres:5432/dictaphone

# 32+ byte random secret. Used by Better Auth to sign session cookies and
# rotate JWKS signing keys. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-strong-random-secret

# Public base URL. Must match what the browser uses or cookies will not stick.
BETTER_AUTH_URL=http://localhost:3000

# --- First-boot admin seed (consumed only when the users table has no admin) ---

ADMIN_EMAIL=admin@dictaphone.local
ADMIN_PASSWORD=change-me-strong-password

# --- Postgres container (compose only) ---

POSTGRES_USER=dictaphone
POSTGRES_PASSWORD=dictaphone
POSTGRES_DB=dictaphone

# --- Optional ---

NEXT_TELEMETRY_DISABLED=1
